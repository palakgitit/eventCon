<!doctype html>
<html class="no-js" lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <title>Edit Event | EventCon</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="shortcut icon" type="image/x-icon" href="/assets/img/favicon.png">

    <!-- Template CSS -->
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css">
    <link rel="stylesheet" href="/assets/css/owl.carousel.min.css">
    <link rel="stylesheet" href="/assets/css/magnific-popup.css">
    <link rel="stylesheet" href="/assets/css/font-awesome.min.css">
    <link rel="stylesheet" href="/assets/css/themify-icons.css">
    <link rel="stylesheet" href="/assets/css/gijgo.css">
    <link rel="stylesheet" href="/assets/css/nice-select.css">
    <link rel="stylesheet" href="/assets/css/animate.css">
    <link rel="stylesheet" href="/assets/css/flaticon.css">
    <link rel="stylesheet" href="/assets/css/slicknav.css">
    <link rel="stylesheet" href="/assets/css/style.css">

    <!-- Custom Edit Event CSS -->
    <link rel="stylesheet" href="/assets/css/editEvent.css">
</head>

<body>

    <header>
        <div class="container mt-5">
            <img src="/assets/img/logo.png" alt="img-logo">
        </div>
    </header>
    <section class="edit-event-area">

        <div class="container">

            <div class="row justify-content-center">

                <div class="col-lg-12">

                    <div class="edit-event-box">

                        <div class="row g-0 ">

                            <!-- Event Image -->

                            <div class="col-lg-5">

                                <div class="event-preview">

                                    <% if(event.image){ %>

                                        <img src="/uploads/<%= event.image %>" alt="<%= event.title %>">

                                        <% } else { %>

                                            <img src="https://placehold.co/600x800" alt="Event">

                                            <% } %>

                                </div>

                            </div>

                            <!-- Edit Form -->

                            <div class="col-lg-7">

                                <div class="edit-form-content">

                                    <span class="section-tag">
                                        Event Management
                                    </span>

                                    <h2>
                                        Edit Event
                                    </h2>

                                    <form action="/updateEvent/<%= event._id %>" method="POST"
                                        enctype="multipart/form-data">

                                        <div class="single-field">

                                            <label>Event Title</label>

                                            <input type="text" name="title" value="<%= event.title %>" required>

                                        </div>

                                        <div class="row">

                                            <div class="col-md-6">

                                                <div class="single-field">

                                                    <label>Event Date</label>

                                                    <input type="date" name="eventDate"
                                                        value="<%= new Date(event.eventDate).toISOString().split('T')[0] %>"
                                                        required>

                                                </div>

                                            </div>

                                           
                                            <div class="col-md-6">

                                                <div class="single-field">

                                                    <label>Event Time</label>

                                                    <input type="time" name="eventTime" value="<%= event.eventTime %>"
                                                        required>

                                                </div>

                                            </div>
                                           
                                            <div class="col-md-12">
                                                <div class="single-field">
                                                    <label>Ticket Price</label>
                                                
                                                    <input type="number" name="price" value="<%= event.price %>" required>
                                                </div>
                                            </div>


                                        </div>

                                        <div class="single-field">

                                            <label>Location</label>

                                            <input type="text" name="location" value="<%= event.location %>" required>

                                        </div>

                                        <div class="single-field">

                                            <label>Change Event Banner</label>

                                            <input type="file" name="image">

                                        </div>

                                        <div class="single-field">

                                            <label>Description</label>

                                            <textarea rows="5" name="description"
                                                required><%= event.description %></textarea>

                                        </div>

                                        <div class="button-group">

                                            <button type="submit" class="boxed-btn3">

                                                Update Event

                                            </button>

                                            <a href="/viewEvent" class="cancel-btn">

                                                Cancel

                                            </a>

                                        </div>

                                    </form>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>

    <!-- JS -->
    <script src="/assets/js/vendor/modernizr-3.5.0.min.js"></script>
    <script src="/assets/js/vendor/jquery-1.12.4.min.js"></script>
    <script src="/assets/js/popper.min.js"></script>
    <script src="/assets/js/bootstrap.min.js"></script>
    <script src="/assets/js/owl.carousel.min.js"></script>
    <script src="/assets/js/isotope.pkgd.min.js"></script>
    <script src="/assets/js/ajax-form.js"></script>
    <script src="/assets/js/waypoints.min.js"></script>
    <script src="/assets/js/jquery.counterup.min.js"></script>
    <script src="/assets/js/imagesloaded.pkgd.min.js"></script>
    <script src="/assets/js/scrollIt.js"></script>
    <script src="/assets/js/jquery.scrollUp.min.js"></script>
    <script src="/assets/js/wow.min.js"></script>
    <script src="/assets/js/gijgo.min.js"></script>
    <script src="/assets/js/nice-select.min.js"></script>
    <script src="/assets/js/jquery.slicknav.min.js"></script>
    <script src="/assets/js/jquery.magnific-popup.min.js"></script>
    <script src="/assets/js/tilt.jquery.js"></script>
    <script src="/assets/js/plugins.js"></script>

</body>

</html>