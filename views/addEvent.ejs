    <!--  form to add the events -->

    <section class="add-event-area">

        <div class="container">

            <div class="row justify-content-center">

                <div class="col-lg-10">

                    <div class="add-event-box">

                        <div class="add-event-header">

                            <span class="section-tag">
                                Event Management
                            </span>

                            <h2>
                                Add New Event
                            </h2>

                        </div>

                        <div class="add-event-body">

                            <form action="/addEvent" method="POST" enctype="multipart/form-data">

                                <div class="mb-4">

                                    <label>
                                        Event Title
                                    </label>

                                    <input type="text" name="title" placeholder="Enter event title" required>

                                </div>

                                <div class="row">

                                    <div class="col-md-6 mb-4">

                                        <label>
                                            Event Date
                                        </label>

                                        <input type="date" name="eventDate" required>

                                    </div>
                                   

                                    <div class="col-md-6 mb-4">

                                        <label>
                                            Event Time
                                        </label>

                                        <input type="time" name="eventTime" required>

                                    </div>

                                    <div class="col-md-12 mb-12">
                                        <div class="mb-4">
                                            <label>Ticket Price</label>
                                        
                                            <input type="number" name="price" placeholder="Enter ticket price" required>
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-4">

                                    <label>
                                        Location
                                    </label>

                                    <input type="text" name="location" placeholder="Enter event location" required>

                                </div>

                                <div class="mb-4">

                                    <label>
                                        Event Banner
                                    </label>

                                    <input type="file" name="image" accept="image/*">

                                </div>

                                <div class="mb-4">

                                    <label>
                                        Description
                                    </label>

                                    <textarea name="description" placeholder="Write event details..."
                                        required></textarea>

                                </div>

                                <div class="add-btn-group">

                                    <button type="submit" class="boxed-btn3">

                                        Create Event

                                    </button>

                                    <button type="reset" class="btn-reset-custom">

                                        Reset

                                    </button>

                                </div>

                            </form>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>




