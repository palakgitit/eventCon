                            </div>
                            <div class="shape_2 wow fadeInDown" data-wow-duration="1s" data-wow-delay=".3s">
                                <img src="assets/img/shape/shape_2.svg" alt="">
                            </div>
                                <h3 class="wow fadeInRight" data-wow-duration="1s" data-wow-delay=".3s">View  Event</h3>
                          </div>
                       </div>
                    </div>
              </div>
           </div>
     </div>
   

     <!--  THE VIEW EVENT -->

    <section class="event-section">
    
        <div class="container px-5">
    
            <% if(events.length> 0){ %>
    
                <% events.forEach(event=> { %>
    
                    <div class="event-card mb-5">
    
                        <div class="row g-0 align-items-center">
    
                            <!-- Image -->
    
                            <div class="col-lg-4">
    
                                <% if(event.image){ %>
    
                                    <img src="/uploads/<%= event.image %>" alt="<%= event.title %>" class="event-image">
    
                                    <% } else { %>
    
                                        <img src="https://placehold.co/600x400" alt="Event" class="event-image">
    
                                        <% } %>
    
                            </div>
    
                            <!-- Content -->
    
                            <div class="col-lg-8">
    
                                <div class="event-content">
    
                                    <div class="event-date">
    
                                        <%= new Date(event.eventDate).toLocaleDateString( "en-GB" , { day: "2-digit" ,
                                            month: "short" , year: "numeric" } ) %>
    
                                    </div>
    
                                    <h2 class="event-title">
                                        <%= event.title %>
                                    </h2>
    
                                    <div class="event-location">
                                        <%= event.location %>
                                    </div>

                                    <span class="event-price">
                                        ₹ <%= event.price %>
                                    </span>
    
                                    <p class="event-description">
                                        <%= event.description %>
                                    </p>
    
                                    <div class="event-time">
                                        <strong>Time:</strong>
                                        <%= event.eventTime %>
                                    </div>
    
                                    <div class="action-buttons">
    
                                        <a href="/editEvent/<%= event._id %>" class="btn btn-edit text-white">
    
                                            Edit Event
                                        </a>
    
                                        <a href="/deleteEvent/<%= event._id %>" class="btn btn-delete text-white"
                                            onclick="return confirm('Are you sure you want to delete this event?');">
    
                                            Delete Event
                                        </a>
    
                                    </div>
    
                                </div>
    
                            </div>
    
                        </div>
    
                    </div>
    
                    <% }) %>
    
                        <% } else { %>
    
                            <div class="no-events">
                                No Events Available
                            </div>
    
                            <% } %>
    
        </div>
    
    </section>

     
    <!-- brand_area_end  -->
